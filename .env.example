# ===== Azure OpenAI (留空则自动使用 Mock 模式，可无凭据演示) =====
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ===== Azure AI Search (留空则使用本地 ChromaDB；配置后启用混合检索) =====
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_PREFIX=bidkb
# 向量维度：Mock=256；真实 text-embedding-3-small=1536，请同步修改
EMBEDDING_DIM=256

# ===== 数据与向量库路径 =====
DATA_DIR=data/knowledge
CHROMA_DIR=data/chroma
COLLECTION_NAME=bid_knowledge

# ===== 分块 / 检索 =====
CHUNK_SIZE=280
CHUNK_OVERLAP=80
TOP_K=5

# ===== 认证 =====
AUTH_SECRET=dev-secret-change-me
TOKEN_TTL_HOURS=12
